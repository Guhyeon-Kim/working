#!/bin/sh
# Working Hub 자동 동기화 훅 (git pull / git merge 후 실행).
#
# 역할:
#   1. Working Hub 경로 자동 탐지 (Windows·Codespace·macOS 공통)
#   2. user-scope sync — ~/.claude/hooks, ~/.claude/skills 갱신
#   3. 현재 repo가 hub 자체가 아니면:
#      - 공용 에이전트 sync (MANIFEST 기반, 고유 에이전트는 보존)
#      - scripts/delegate.mjs 최신화 (Windows cmd.exe 래퍼 등)
#
# 크로스 플랫폼: Git for Windows의 Git Bash에서도 동일하게 실행.
# 비파괴: 실패하더라도 exit 0으로 git 작업을 막지 않음.

if ! command -v node >/dev/null 2>&1; then
  echo "[post-merge] node 미설치 — sync 스킵" >&2
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -z "$REPO_ROOT" ] && exit 0

# ── Working Hub 경로 자동 탐지 ──
find_hub() {
  # 1) 이 repo 자체가 working hub면 그대로 사용.
  #    release-to-dotfiles.mjs는 working hub에만 존재하는 고유 지표.
  if [ -f "$REPO_ROOT/scripts/release-to-dotfiles.mjs" ] && [ -d "$REPO_ROOT/agents" ]; then
    echo "$REPO_ROOT"
    return 0
  fi
  # 2) 알려진 후보 경로 순차 시도 (Windows / Codespace / macOS / Linux)
  for candidate in \
    "$HOME/Desktop/프로젝트/working" \
    "/workspaces/working" \
    "$HOME/working" \
    "$HOME/.claude-config"; do
    if [ -f "$candidate/scripts/sync-user-scope.mjs" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

HUB=$(find_hub)
if [ -z "$HUB" ]; then
  echo "[post-merge] working hub를 찾지 못함 — 수동 sync 필요" >&2
  exit 0
fi

echo "[post-merge] hub: $HUB"

# ── 1. 상태 판정: fresh machine이면 full bootstrap, 아니면 sync만 ──
# "실행 후 삭제" 원칙: sentinel 파일을 쓰지 않고 ~/.claude-config·hooks 실존으로
# 상태를 판정한다. fresh machine에서 bootstrap이 1회 돌고 나면 다음 pull부턴
# 같은 조건이 false가 돼 sync 경로만 타게 된다 (자기 자체가 one-shot처럼 동작).
NEEDS_BOOTSTRAP=""
if [ ! -d "$HOME/.claude-config" ]; then
  NEEDS_BOOTSTRAP="dotfiles 없음"
elif [ ! -d "$HOME/.claude/hooks" ] || [ -z "$(ls -A "$HOME/.claude/hooks" 2>/dev/null)" ]; then
  NEEDS_BOOTSTRAP="~/.claude/hooks 비어있음"
fi

if [ -n "$NEEDS_BOOTSTRAP" ] && [ -f "$HUB/scripts/bootstrap.mjs" ]; then
  echo "[post-merge] fresh machine 감지 ($NEEDS_BOOTSTRAP) — bootstrap --apply 실행" >&2
  node "$HUB/scripts/bootstrap.mjs" --apply || \
    echo "[post-merge] bootstrap 일부 실패 — 수동 확인: node scripts/bootstrap.mjs --apply" >&2
else
  node "$HUB/scripts/sync-user-scope.mjs" >/dev/null 2>&1 || \
    echo "[post-merge] user-scope sync 일부 실패" >&2
fi

# 현재 repo가 hub 자체면 여기서 종료
if [ "$REPO_ROOT" = "$HUB" ]; then
  exit 0
fi

# ── 2. 이 repo의 공용 에이전트 sync ──
if [ -f "$HUB/scripts/sync-shared-agents.mjs" ]; then
  node "$HUB/scripts/sync-shared-agents.mjs" "$REPO_ROOT" 2>&1 | tail -1
fi

# ── 3. scripts/delegate.mjs 최신화 ──
if [ -f "$HUB/scripts/delegate.mjs" ] && [ -d "$REPO_ROOT/scripts" ]; then
  cp -f "$HUB/scripts/delegate.mjs" "$REPO_ROOT/scripts/delegate.mjs"
fi

exit 0
