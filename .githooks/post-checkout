#!/bin/sh
# 브랜치 전환 시 working hub 공용 인프라 재동기화.
# post-checkout args: $1=prev HEAD, $2=new HEAD, $3=flag (1=branch, 0=file)
# branch checkout일 때만 실행 (개별 파일 checkout마다 돌면 과함).

[ "$3" = "1" ] || exit 0

if ! command -v node >/dev/null 2>&1; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -z "$REPO_ROOT" ] && exit 0

# Working Hub 경로 자동 탐지 (post-merge와 동일)
find_hub() {
  # release-to-dotfiles.mjs는 working hub 고유 지표.
  if [ -f "$REPO_ROOT/scripts/release-to-dotfiles.mjs" ] && [ -d "$REPO_ROOT/agents" ]; then
    echo "$REPO_ROOT"
    return 0
  fi
  for candidate in \
    "$HOME/Desktop/프로젝트/working" \
    "/workspaces/working" \
    "$HOME/working" \
    "$HOME/.claude-config"; do
    if [ -f "$candidate/scripts/sync-user-scope.mjs" ]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

HUB=$(find_hub)
[ -z "$HUB" ] && exit 0

# 현재 repo가 hub면: hooks/skills/settings.json 변경이 있을 때만 user-scope sync
if [ "$REPO_ROOT" = "$HUB" ]; then
  CHANGED=$(git diff --name-only "$1" "$2" 2>/dev/null | grep -E "^(hooks|skills)/|^settings\.json$" | head -1)
  [ -z "$CHANGED" ] && exit 0
  node "$HUB/scripts/sync-user-scope.mjs" >/dev/null 2>&1 || \
    echo "[post-checkout] sync 실패" >&2
  exit 0
fi

# 일반 repo: 공용 에이전트 sync + delegate.mjs 최신화 (브랜치 전환 시 놓치지 않도록)
[ -f "$HUB/scripts/sync-shared-agents.mjs" ] && \
  node "$HUB/scripts/sync-shared-agents.mjs" "$REPO_ROOT" >/dev/null 2>&1

if [ -f "$HUB/scripts/delegate.mjs" ] && [ -d "$REPO_ROOT/scripts" ]; then
  cp -f "$HUB/scripts/delegate.mjs" "$REPO_ROOT/scripts/delegate.mjs"
fi

exit 0
